APP_NAME=photo-gallery-api
APP_ENV=dev
APP_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change_this_secret
JWT_EXPIRE_SECONDS=3600
DATABASE_DSN=host=localhost user=postgres password=postgres dbname=photogallery port=5432 sslmode=disable
SEED_ENABLED=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin123*
SEED_SELLER_USERNAME=vendedor
SEED_SELLER_PASSWORD=Vendedor123*
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=photogallery
POSTGRES_PORT=5432
PGADMIN_DEFAULT_EMAIL=admin@photogallery.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050
FILES_BASE_PATH=./storage
FILES_MAX_SIZE_MB=25
FILES_ALLOWED_MIME=image/jpeg,image/png,application/pdf
CUSTOMER_KEY_MODE=both
